# Server
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

# Supabase (required)
# From Supabase Dashboard: Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Project Settings → API → JWT Settings → JWT Secret (for verifying access tokens)
SUPABASE_JWT_SECRET=your-jwt-secret

# Google Calendar / Meet (create meeting links)
GOOGLE_CALENDAR_CREDENTIALS=./google-calendar-credentials.json

# WhatsApp (optional)
WHATSAPP_API_URL=
WHATSAPP_API_KEY=

# Email (e.g. Resend or SMTP)
EMAIL_PROVIDER=resend
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=PeerNXT <noreply@peernxt.com>

# Frontend URL (for CORS and links in emails)
# User Vite app: port 3000; Admin Vite app: port 3002 (see each frontend/vite.config.ts)
FRONTEND_URL=http://localhost:3000
FRONTEND_URLS=http://localhost:3000,http://localhost:3002

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
