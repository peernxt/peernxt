# Copy to .env.local and fill real values from Supabase (Settings → API).
# Admin app runs on Vite port 3002 by default (vite.config.ts).
VITE_API_BASE_URL=/api/v1
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
# Set true only for temporary local UI testing without login
VITE_SKIP_AUTH=false

