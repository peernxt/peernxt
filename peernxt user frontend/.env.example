# Copy to .env.local and fill real values from Supabase (Settings → API).
# This app runs on Vite port 3000 by default (vite.config.ts).
# Dev: `/api/v1` uses Vite proxy to backend (port 4000). Production: full URL, e.g. https://api.example.com/api/v1
VITE_API_BASE_URL=/api/v1
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
# Must match the origin you use in the browser (default user app port 3000 — see vite.config.ts)
# Add the same URL in Supabase → Authentication → URL configuration → Redirect URLs
VITE_AUTH_REDIRECT_ORIGIN=http://localhost:3000
# Set true only for temporary local UI testing without login
VITE_SKIP_AUTH=false

